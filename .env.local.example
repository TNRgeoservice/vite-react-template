# ════════════════════════════════════════
# .env.local — TNR MapHub (Next.js)
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ════════════════════════════════════════

# Firebase (Client-side — NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyATOapsG-1fS8T08d_VaQgRp6D0xvbPw1g
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sharedcalendar-d108f.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sharedcalendar-d108f
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sharedcalendar-d108f.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=103287743987
NEXT_PUBLIC_FIREBASE_APP_ID=1:103287743987:web:dec560d1968111e2901e86
NEXT_PUBLIC_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY

# Firebase Admin (Server-side only — no NEXT_PUBLIC_)
# Download from Firebase Console → Project Settings → Service accounts
FIREBASE_ADMIN_PROJECT_ID=sharedcalendar-d108f
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@sharedcalendar-d108f.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# Google Maps (for Street View)
NEXT_PUBLIC_GMAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Site URL
NEXT_PUBLIC_SITE_URL=https://tnrmaphub.netlify.app
